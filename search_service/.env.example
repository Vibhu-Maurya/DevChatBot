# Server Configuration
PORT=8000
HOST=0.0.0.0

# Qdrant Database Configuration
# Fallback to local 'qdrant_db' path if server is empty or offline
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_PATH=../crawler/qdrant_db
COLLECTION_NAME=docs_v1

# Qdrant Cloud Configuration (Optional)
# Enter these to use a persistent remote DB for free tier hosting
QDRANT_URL=your_qdrant_cloud_url_here
QDRANT_API_KEY=your_qdrant_cloud_api_key_here

# LLM Providers API Keys
# At least GEMINI_API_KEY or OPENAI_API_KEY must be provided for RAG (/ask)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LLM Default Settings
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.5-flash
